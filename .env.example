# Jenga 3D — Environment Variables Template
# Copy this to .env.local for development

# Google Analytics
VITE_GA_ID=G-XXXXXXXXXX

# AdSense (optional — leave empty for dev)
VITE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_AD_BANNER_SLOT=XXXXXXXXXX
VITE_AD_REWARDED_SLOT=XXXXXXXXXX

# Firebase (optional — needed for online leaderboard)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Payment links (optional — needed for premium store)
VITE_PAYMENT_SKIN_PACK=
VITE_PAYMENT_REMOVE_ADS=
VITE_PAYMENT_ENV_THEMES=

# Purchase verification (optional — server URL for receipt validation)
VITE_PURCHASE_VERIFICATION_URL=

# Site URL (for social sharing)
VITE_SITE_URL=http://localhost:5173

# Online multiplayer server
VITE_WS_URL=ws://localhost:3001
VITE_API_URL=http://localhost:3001
